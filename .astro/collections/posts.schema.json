{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "default": ""
        },
        "category": {
          "type": "string",
          "enum": [
            "skills",
            "insights",
            "book-notes",
            "hot-reports",
            "writing-system",
            "course"
          ],
          "default": "skills"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "author": {
          "type": "string",
          "default": "杰哥 AI TEAM"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ],
          "default": "2026-03-28T13:09:33.226Z"
        },
        "modified": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "cover": {
          "type": "string"
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "toc": {
          "type": "boolean",
          "default": true
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}