---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '../utils/data/categories';

// 获取所有文章用于客户端搜索
const posts = await getCollection('posts', ({ data }) => {
  return data.draft !== true;
});

const searchData = posts.map(post => ({
  slug: post.id,
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  date: post.data.date.toISOString(),
}));

// 按日期排序
searchData.sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
---

<BaseLayout title="搜索" description="搜索博客文章">
  <div class="max-w-3xl mx-auto animate-slide-up">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-text-primary mb-4 flex items-center gap-3">
        <span class="text-4xl">🔍</span>
        搜索文章
      </h1>
      <p class="text-text-secondary">输入关键词搜索博客文章，支持标题、描述、标签搜索</p>
    </header>
    
    <div class="mb-6">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="输入关键词搜索..."
          class="w-full px-4 py-3.5 pl-14 bg-bg-secondary border border-border rounded-xl text-text-primary placeholder-text-muted focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all duration-300 shadow-sm focus:shadow-lg"
        />
        <svg class="absolute left-5 top-1/2 -translate-y-1/2 w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <!-- 清除按钮 -->
        <button 
          id="clear-btn"
          class="absolute right-4 top-1/2 -translate-y-1/2 p-1 rounded-full bg-bg-tertiary hover:bg-bg-hover text-text-muted hover:text-text-secondary transition-all hidden"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <!-- 快捷标签 -->
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="text-sm text-text-muted">热门搜索：</span>
        <button class="quick-tag px-3 py-1 rounded-full text-xs bg-bg-tertiary text-text-secondary hover:bg-primary-subtle hover:text-primary transition-all" data-query="AI">AI</button>
        <button class="quick-tag px-3 py-1 rounded-full text-xs bg-bg-tertiary text-text-secondary hover:bg-primary-subtle hover:text-primary transition-all" data-query="视频">视频</button>
        <button class="quick-tag px-3 py-1 rounded-full text-xs bg-bg-tertiary text-text-secondary hover:bg-primary-subtle hover:text-primary transition-all" data-query="写作">写作</button>
        <button class="quick-tag px-3 py-1 rounded-full text-xs bg-bg-tertiary text-text-secondary hover:bg-primary-subtle hover:text-primary transition-all" data-query="DeepSeek">DeepSeek</button>
        <button class="quick-tag px-3 py-1 rounded-full text-xs bg-bg-tertiary text-text-secondary hover:bg-primary-subtle hover:text-primary transition-all" data-query="ChatGPT">ChatGPT</button>
      </div>
    </div>
    
    <!-- 搜索状态 -->
    <div id="search-status" class="mb-4 text-sm text-text-muted hidden">
      找到 <span id="result-count" class="font-semibold text-primary">0</span> 篇相关文章
    </div>
    
    <!-- 搜索结果 -->
    <div id="search-results" class="space-y-4"></div>
    
    <!-- 无结果 -->
    <div id="no-results" class="hidden text-center py-16 animate-fade-in">
      <div class="text-6xl mb-4">🔎</div>
      <p class="text-text-muted text-lg mb-2">未找到相关文章</p>
      <p class="text-text-secondary text-sm">试试其他关键词？</p>
    </div>
    
    <!-- 初始状态 -->
    <div id="initial-state" class="text-center py-16">
      <div class="text-6xl mb-4 animate-float">📚</div>
      <p class="text-text-muted text-lg mb-2">输入关键词开始搜索</p>
      <p class="text-text-secondary text-sm">共有 <span class="font-semibold text-accent-blue">{searchData.length}</span> 篇文章等你探索</p>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ searchData, categories }}>
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const noResults = document.getElementById('no-results');
  const initialState = document.getElementById('initial-state');
  const searchStatus = document.getElementById('search-status');
  const resultCount = document.getElementById('result-count');
  const clearBtn = document.getElementById('clear-btn');
  const quickTags = document.querySelectorAll('.quick-tag');
  
  const categoryMap = {};
  categories.forEach(c => {
    categoryMap[c.id] = { name: c.name, icon: c.icon, color: c.color };
  });
  
  // 高亮匹配文本
  function highlightText(text, query) {
    if (!query || !text) return text;
    const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
    return text.replace(regex, '<mark class="bg-primary-subtle text-primary px-1 rounded">$1</mark>');
  }
  
  function performSearch(query) {
    // 显示/隐藏清除按钮
    clearBtn.classList.toggle('hidden', !query.trim());
    
    // 隐藏初始状态
    initialState.classList.add('hidden');
    
    if (!query.trim()) {
      searchResults.innerHTML = '';
      noResults.classList.add('hidden');
      searchStatus.classList.add('hidden');
      initialState.classList.remove('hidden');
      return;
    }
    
    const lowerQuery = query.toLowerCase();
    const results = searchData.filter(post => 
      post.title.toLowerCase().includes(lowerQuery) ||
      post.description.toLowerCase().includes(lowerQuery) ||
      post.tags.some(tag => tag.toLowerCase().includes(lowerQuery)) ||
      post.category.toLowerCase().includes(lowerQuery)
    );
    
    // 显示搜索状态
    searchStatus.classList.remove('hidden');
    resultCount.textContent = results.length;
    
    if (results.length === 0) {
      searchResults.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }
    
    noResults.classList.add('hidden');
    
    searchResults.innerHTML = results.map((post, idx) => {
      const cat = categoryMap[post.category] || { name: post.category, icon: '📄', color: '#6366F1' };
      const date = new Date(post.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
      const highlightedTitle = highlightText(post.title, query);
      const highlightedDesc = highlightText(post.description, query);
      
      return `
        <a href="/post/${post.slug}" class="block p-5 glass-post-card card-hover animate-slide-up" style="animation-delay: ${idx * 50}ms">
          <div class="flex items-center gap-3 mb-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium animate-scale-in" style="background-color: ${cat.color}15; color: ${cat.color}; border: 1px solid ${cat.color}30; animation-delay: ${idx * 50 + 100}ms">
              <span class="text-sm">${cat.icon}</span>
              <span>${cat.name}</span>
            </span>
            <time class="text-xs text-text-muted flex items-center gap-1">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M8 21v-4m8 4v-4" />
              </svg>
              ${date}
            </time>
          </div>
          <h3 class="text-lg font-semibold text-text-primary mb-2">${highlightedTitle}</h3>
          ${post.description ? `<p class="text-sm text-text-secondary line-clamp-2 leading-relaxed">${highlightedDesc}</p>` : ''}
          ${post.tags && post.tags.length > 0 ? `
            <div class="mt-3 flex flex-wrap gap-1.5">
              ${post.tags.slice(0, 3).map(tag => `
                <span class="px-2 py-0.5 rounded text-xs bg-bg-tertiary text-text-muted">#${tag}</span>
              `).join('')}
              ${post.tags.length > 3 ? `<span class="text-xs text-text-muted">+${post.tags.length - 3}</span>` : ''}
            </div>
          ` : ''}
        </a>
      `;
    }).join('');
  }
  
  // 防抖
  let debounceTimer;
  function debounce(func, delay) {
    return function(...args) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => func.apply(this, args), delay);
    };
  }
  
  searchInput.addEventListener('input', debounce((e) => {
    performSearch(e.target.value);
  }, 200));
  
  // 清除按钮
  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    performSearch('');
    searchInput.focus();
  });
  
  // 快捷标签
  quickTags.forEach(tag => {
    tag.addEventListener('click', () => {
      const query = tag.dataset.query;
      searchInput.value = query;
      performSearch(query);
    });
  });
  
  // 自动聚焦
  searchInput.focus();
</script>