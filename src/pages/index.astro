---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PostCard from '../components/PostCard.astro';
import { getLatestPosts } from '../utils/content';

const latestPosts = await getLatestPosts(10);
---

<BaseLayout title="AI 写作博客" description="探索 AI、写作与人类潜能的边界">
  <!-- Hero Section - Dan Koe Style -->
  <Hero />
  
  <!-- Latest Posts with Cover Images -->
  {latestPosts.length > 0 && (
    <section class="py-12">
      <h2 class="text-center text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-8">最新文章</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {latestPosts.map((post, idx) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.id}
            image={post.data.image}
            featured={post.data.featured}
            index={idx}
          />
        ))}
      </div>
      
      <div class="text-center mt-10">
        <a href="/tags" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-primary)] transition-colors">
          查看全部文章
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </section>
  )}
</BaseLayout>