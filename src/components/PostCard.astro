---
import { categories } from '../utils/data/categories'

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  slug: string;
  cover?: string;
  featured?: boolean;
  index?: number;
}

const { title, description, date, category, tags, slug, cover, featured, index = 0 } = Astro.props;

const categoryInfo = categories.find(c => c.id === category);
const formattedDate = date ? date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
}) : '';

// 计算阅读时间
const readingTime = Math.ceil((description?.length || 0) / 200) + 3;

const postUrl = `/post/${slug}`;

// Stagger delay based on index
const staggerDelay = Math.min(index * 50, 400);
---

<article 
  class="glass-post-card card-hover group overflow-hidden animate-slide-up"
  style={`animation-delay: ${staggerDelay}ms`}
>
  <!-- 封面图片 -->
  <a href={postUrl} class="block">
    <div class="aspect-video bg-[var(--color-bg-tertiary)] overflow-hidden relative">
      {cover ? (
        <img 
          src={cover} 
          alt={title}
          class="w-full h-full object-cover transition-all duration-500 group-hover:scale-110 group-hover:brightness-95"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center relative overflow-hidden">
          <!-- 动态渐变背景 -->
          <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-bg-tertiary)] via-[var(--color-bg-secondary)] to-[var(--color-bg-tertiary)] animate-shimmer"></div>
          <!-- 装饰光点 -->
          <div class="absolute top-1/4 left-1/4 w-16 h-16 bg-[var(--color-primary)]/20 rounded-full blur-xl animate-float opacity-60"></div>
          <div class="absolute bottom-1/4 right-1/4 w-12 h-12 bg-[var(--color-accent-blue)]/20 rounded-full blur-xl animate-float opacity-60" style="animation-delay: 500ms"></div>
          <!-- 分类图标 -->
          <span class="text-6xl opacity-50 transition-transform duration-300 group-hover:scale-125 group-hover:opacity-70 animate-float relative z-10" style="animation-delay: ${(index * 100) % 1000 + 200}ms">{categoryInfo?.icon || '📝'}</span>
        </div>
      )}
      <!-- 精选标记 -->
      {featured && (
        <div class="absolute top-3 right-3 animate-glow">
          <span class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-medium bg-amber-500/90 text-white shadow-lg backdrop-blur-sm">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            精选
          </span>
        </div>
      )}
      <!-- 阅读时间角标 -->
      <div class="absolute bottom-3 left-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        <span class="inline-flex items-center gap-1 px-2 py-1 rounded text-xs bg-[var(--color-bg-primary)]/80 text-[var(--color-text-primary)] backdrop-blur-sm border border-[var(--glass-border)]">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          {readingTime} 分钟阅读
        </span>
      </div>
    </div>
  </a>
  
  <!-- 文章信息 -->
  <div class="p-5">
    <!-- 分类标签 -->
    <div class="mb-3 flex items-center gap-2">
      <a 
        href={`/category/${category}`}
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-200 hover:shadow-md animate-scale-in"
        style={`background-color: ${categoryInfo?.color || '#6366F1'}15; color: ${categoryInfo?.color || '#6366F1'}; border: 1px solid ${categoryInfo?.color || '#6366F1'}30; animation-delay: ${staggerDelay + 100}ms`}
      >
        <span class="text-sm">{categoryInfo?.icon}</span>
        <span>{categoryInfo?.name}</span>
      </a>
    </div>
    
    <!-- 标题 -->
    <h2 class="font-bold text-xl text-[var(--color-text-primary)] mb-3 leading-tight">
      <a href={postUrl} class="hover:text-[var(--color-primary)] transition-colors duration-200 line-clamp-2">
        {title}
      </a>
    </h2>
    
    <!-- 摘要 -->
    <p class="text-sm text-[var(--color-text-secondary)] mb-4 line-clamp-2 leading-relaxed">
      {description || '点击查看文章详情...'}
    </p>
    
    <!-- 元信息 -->
    <div class="flex items-center justify-between text-xs text-[var(--color-text-muted)]">
      <div class="flex items-center gap-2">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M8 21v-4m8 4v-4"/>
          </svg>
          {formattedDate}
        </span>
      </div>
      
      <!-- 标签 -->
      <div class="flex items-center gap-1.5 overflow-hidden">
        {tags?.slice(0, 2).map(tag => (
          <a 
            href={`/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
            class="px-2 py-0.5 rounded text-xs bg-[var(--color-bg-secondary)] hover:bg-[var(--color-primary)]10 hover:text-[var(--color-primary)] transition-all duration-200 whitespace-nowrap"
          >
            #{tag}
          </a>
        ))}
        {tags?.length > 2 && (
          <span class="text-xs text-[var(--color-text-muted)]">+{tags.length - 2}</span>
        )}
      </div>
    </div>
  </div>
</article>