---
const currentYear = new Date().getFullYear();
---

<footer class="glass border-t border-[var(--glass-border)] mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div class="animate-slide-up">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl animate-float">🌟</span>
          <span class="font-bold text-xl gradient-text">AI写作博客</span>
        </div>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          AI 时代的内容创作实验室。探索 AI 技能、洞察行业趋势、提升写作能力。
        </p>
      </div>
      
      <!-- Quick Links -->
      <div class="animate-slide-up" style="animation-delay: 100ms">
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-4">快速链接</h3>
        <nav class="flex flex-col gap-2">
          <a href="/category/skills" class="link-hover text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">AI 技能</a>
          <a href="/category/insights" class="link-hover text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">技术洞察</a>
          <a href="/category/book-notes" class="link-hover text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">读书笔记</a>
          <a href="/archives" class="link-hover text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">文章归档</a>
        </nav>
      </div>
      
      <!-- Social -->
      <div class="animate-slide-up" style="animation-delay: 200ms">
        <h3 class="font-semibold text-[var(--color-text-primary)] mb-4">关注我们</h3>
        <div class="flex gap-4">
          <a href="https://github.com/furioussoul/jiege_ai_team_blog" target="_blank" rel="noopener" class="glass-border p-2 rounded-lg btn-click text-[var(--color-text-secondary)] hover:text-white hover:bg-[var(--color-primary)] transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://x.com/snzhngji869582?s=21" target="_blank" rel="noopener" class="glass-border p-2 rounded-lg btn-click text-[var(--color-text-secondary)] hover:text-white hover:bg-[var(--color-primary)] transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="https://space.bilibili.com/270076899" target="_blank" rel="noopener" class="glass-border p-2 rounded-lg btn-click text-[var(--color-text-secondary)] hover:text-white hover:bg-[var(--color-primary)] transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.75 3.75h10.5v1.5H6.75v-1.5zm-2.25 3h15v10.5h-15V6.75zm3 3v4.5h3v-4.5h-3zm6 0v4.5h3v-4.5h-3z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Copyright -->
    <div class="border-t border-[var(--color-border)] mt-8 pt-8 text-center animate-fade-in" style="animation-delay: 300ms">
      <p class="text-[var(--color-text-muted)] text-sm">
        © {currentYear} AI写作博客. All rights reserved.
      </p>
    </div>
  </div>
</footer>