---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/category/skills', label: '技能' },
  { href: '/category/insights', label: '洞察' },
  { href: '/category/book-notes', label: '读书' },
  { href: '/about', label: '关于' },
];
---

<header class="sticky top-0 z-50 glass border-b border-[var(--glass-border)] animate-slide-up">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="text-2xl font-bold gradient-text group-hover:animate-glow transition-all duration-300">
          🌟 AI写作博客
        </span>
      </a>
      
      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link, idx) => (
          <a
            href={link.href}
            class={`nav-link text-sm font-medium transition-colors animate-fade-in ${
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]'
            }`}
            style={`animation-delay: ${idx * 50}ms`}
          >
            {link.label}
          </a>
        ))}
      </div>
      
      <!-- Right side: Search & Theme -->
      <div class="flex items-center gap-4">
        <!-- Search Link -->
        <a
          href="/search"
          class="flex items-center gap-2 px-3 py-2 rounded-lg glass-border btn-click text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] animate-fade-in"
          style="animation-delay: 200ms"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline text-sm">搜索</span>
        </a>
        
        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg glass-border btn-click animate-fade-in"
          style="animation-delay: 300ms"
          aria-label="打开菜单"
        >
          <svg class="w-6 h-6 text-[var(--color-text-secondary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-2">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'bg-[var(--color-primary-subtle)] text-[var(--color-primary)]'
                : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-secondary)] hover:text-[var(--color-text-primary)]'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  if (mobileMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>