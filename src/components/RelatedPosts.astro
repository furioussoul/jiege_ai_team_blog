---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<div class="mt-6 rounded-lg bg-bg-secondary p-4 border border-border">
  <h3 class="text-sm font-semibold text-text-primary mb-4 flex items-center gap-2">
    <span>📖</span>
    <span>相关文章</span>
  </h3>
  
  <ul class="space-y-2">
    {posts.map((post) => (
      <li>
        <a
          href={`/post/${post.id}`}
          class="text-sm text-text-secondary hover:text-primary transition-colors block py-1 truncate"
        >
          {post.data.title}
        </a>
      </li>
    ))}
  </ul>
</div>